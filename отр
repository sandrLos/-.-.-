def sum_negatives_between_min_max(arr):
    if len(arr) < 3:
        return 0  # Если элементов меньше 3, между min и max не может быть других элементов

    # Находим индексы максимального и минимального элементов
    max_index = arr.index(max(arr))
    min_index = arr.index(min(arr))

    # Определяем границы диапазона (от меньшего индекса к большему)
    start = min(max_index, min_index) + 1
    end = max(max_index, min_index)

    # Суммируем отрицательные элементы между min и max
    sum_negatives = sum(x for x in arr[start:end] if x < 0)

    return sum_negatives

# Пример использования
A = [-10, -5, -2, 7, -1, 15]
result = sum_negatives_between_min_max(A)
print(f"Сумма отрицательных элементов между min и max: {result}")
